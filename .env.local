# ─── Resend API Key ───
# Get this from resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Email that RECEIVES form submissions ───
CONTACT_RECEIVER=your-gmail@gmail.com

# ─── Email that SENDS on behalf of (must be verified in Resend) ───
# For free tier use: onboarding@resend.dev (works immediately, no domain needed)
# Later swap to: noreply@supremeinfotech.com once domain is verified in Resend
CONTACT_SENDER=onboarding@resend.dev